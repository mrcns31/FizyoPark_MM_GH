[Unit]
Description=FizyoPark Kapi Role Kontrol Servisi
After=multi-user.target pigpiod.service
Requires=pigpiod.service

[Service]
Type=simple
User=__APP_USER__
ExecStart=/usr/bin/python3 __APP_DIR__/raspberry-pi/door-control.py
Restart=on-failure
RestartSec=2
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target

# FizyoPark Backend — Ortam Değişkenleri
# Bu dosyayı backend/.env olarak kopyalayın ve değerleri doldurun.

# PostgreSQL bağlantısı (Railway, Supabase veya yerel)
DATABASE_URL=postgresql://kullanici:sifre@sunucu:5432/veritabani

# JWT imzalama anahtarı (en az 32 karakter, rastgele)
JWT_SECRET=buraya-cok-gizli-bir-anahtar-yazin-min-32-karakter

# Sunucu portu
PORT=3000

# Ortam
NODE_ENV=production

# CORS — admin paneli hangi adresten açılıyorsa
# Birden fazla adres virgülle ayrılabilir
CORS_ORIGIN=http://localhost,http://192.168.1.100

# Kapı röle servisi adresi (Pi'de çalışan door-control.py)
# Admin panelindeki "Kapıyı Aç" butonu bu adrese POST atar
DOOR_RASPI_URL=http://127.0.0.1:7000/open

# Rate limiting (isteğe bağlı)
# RATE_LIMIT_DISABLED=1

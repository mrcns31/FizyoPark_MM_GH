# fizyopark-mm web imaji — nginx + statik frontend. Build context: repo koku.
FROM nginx:alpine

# Deploy nginx config (statik + /api proxy + __API_BASE__ inject)
COPY deploy/nginx.conf /etc/nginx/conf.d/default.conf

# Statik frontend dosyalari (sadece gerekli olanlar; backend/docs/mobile haric)
WORKDIR /usr/share/nginx/html
COPY index.html app.js api.js styles.css manifest.json sw.js pwa-register.js ./
COPY kiosk.html kiosk.js activity-logs.html activity-logs.js ./
COPY consent-status.html consent-status.js broadcasts.html broadcasts.js ./
COPY icons/ ./icons/
COPY fonts/ ./fonts/

EXPOSE 80

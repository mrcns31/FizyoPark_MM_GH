# React 19 + RN 0.85 çok yeni; bazı paketlerin peer aralıkları henüz 19'u resmî
# saymıyor. Yeni npm sürümleri (11+) bunda ERESOLVE veriyor. legacy-peer-deps,
# lockfile'dan birebir kurmayı bozmadan peer çakışma kontrolünü gevşetir →
# her makinede (npm sürümünden bağımsız) `npm ci`/`npm install` çalışır.
legacy-peer-deps=true
